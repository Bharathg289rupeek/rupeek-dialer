# Server
PORT=3000
NODE_ENV=development
API_BASE_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rupeek_dialer

# Exotel
EXOTEL_ACCOUNT_SID=your_sid
EXOTEL_API_KEY=your_key
EXOTEL_API_TOKEN=your_token
EXOPHONE=your_exophone_number
EXOTEL_APP_URL=https://my.exotel.com/exoml/start/flow_id
EXOTEL_INBOUND_APP_URL=https://my.exotel.com/exoml/start/inbound_flow_id
EXOTEL_API_BASE=https://api.exotel.com/v1

# Routing Defaults
DEFAULT_RING_DURATION_SEC=20
DEFAULT_MAX_PARALLEL_RMS=3
FALLBACK_CALL_CENTER_NUMBER=+91XXXXXXXXXX

# UTM Lead Creation
UTM_LEAD_ENDPOINT=https://rupeek.com/api/utm-lead
UTM_API_KEY=your_key

# Auth
JWT_SECRET=change_this_to_a_random_secret_in_production
ADMIN_EMAIL=admin@rupeek.com
ADMIN_PASSWORD=admin123

# Business Hours (IST)
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=18:00
TIMEZONE=Asia/Kolkata
